<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".ShareMyThingApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name_short"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShareMyThing">

        <meta-data
            android:name="com.google.android.gms.wearable.capability"
            android:resource="@array/android_wear_capabilities" />

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ShareMyThing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.PhoneWidget1Receiver"
            android:exported="true"
            android:label="@string/phone_widget_1"
            android:theme="@style/Theme.ShareMyThing.AppWidgetContainer">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/phone_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.PhoneWidget2Receiver"
            android:exported="true"
            android:label="@string/phone_widget_2"
            android:theme="@style/Theme.ShareMyThing.AppWidgetContainer">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/phone_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.PhoneWidget3Receiver"
            android:exported="true"
            android:label="@string/phone_widget_3"
            android:theme="@style/Theme.ShareMyThing.AppWidgetContainer">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/phone_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.PhoneWidget4Receiver"
            android:exported="true"
            android:label="@string/phone_widget_4"
            android:theme="@style/Theme.ShareMyThing.AppWidgetContainer">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/phone_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.PhoneWidget5Receiver"
            android:exported="true"
            android:label="@string/phone_widget_5"
            android:theme="@style/Theme.ShareMyThing.AppWidgetContainer">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/phone_widget_info" />
        </receiver>

    </application>

</manifest>
