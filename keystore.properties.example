# Copy to keystore.properties (gitignored) and fill in before signed releases.
# Do not regenerate upload-keystore.jks once Play Console registration is approved.
# Back up upload-keystore.jks and keystore.properties together.
#
# Upload key SHA-256 (local upload-keystore.jks, alias upload):
#   FF:05:C1:1D:4F:EE:B2:A7:52:9F:48:48:1D:41:D1:6C:25:71:EB:DC:17:98:F3:DB:BD:9B:F8:E4:3C:1F:86:C7
#
# Google Play app signing key (different — managed by Google, not this file):
#   77:0C:B5:EC:43:20:0B:EE:27:26:2E:64:96:D8:DA:32:0B:70:A0:5D:CF:3C:B1:94:17:F8:DB:FE:1C:A8:4C:A5

storeFile=upload-keystore.jks
storePassword=change-me
keyAlias=upload
keyPassword=change-me
