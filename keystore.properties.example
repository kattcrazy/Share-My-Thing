# Copy to keystore.properties (gitignored) and fill in before Play Store / signed releases.
# Generate a upload key: keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload

storeFile=upload-keystore.jks
storePassword=change-me
keyAlias=upload
keyPassword=change-me
